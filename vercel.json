{
  "version": 2,
  "builds": [
    { "src": "public/*.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/app", "dest": "/public/app.html" },
    { "src": "/", "dest": "/public/landing.html" },
    { "src": "/(.*)", "dest": "/public/landing.html" }
    { "src": "/dashboard", "dest": "/public/dashboard.html" }
  ]
}
